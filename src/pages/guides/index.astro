---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
  <SiteHeader />
  <div class="ad"></div>
  <main class="guides">
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
    <div class="ad"></div>
  </main>
  <SiteFooter />
</Base>

<style define:vars={{ bg: site.theme.bg, ink: site.theme.ink, accent: site.theme.accent, headingFont: site.theme.headingFont, bodyFont: site.theme.bodyFont }} is:global>
  .ad{max-width:860px;margin:0 auto clamp(32px,7vw,48px);padding:0 clamp(20px,5vw,48px)}
  .ad::before{content:"Advertisement";display:block;text-align:center;font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:rgba(22,18,22,.4);margin-bottom:8px}
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); }
  .guides h1 { font-family: var(--headingFont); }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
