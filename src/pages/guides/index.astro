---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
  <SiteHeader />
  <div class="ad"></div>
  <main class="guides">
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=hissecret&tid=passcosmo_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">His Secret Obsession</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Relationship guide by coach James Bauer — understanding what makes partners commit.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">Read more →</span></a>
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
    <div class="ad"></div>
  </main>
  <SiteFooter />
</Base>

<style define:vars={{ bg: site.theme.bg, ink: site.theme.ink, accent: site.theme.accent, headingFont: site.theme.headingFont, bodyFont: site.theme.bodyFont }} is:global>
  .ad{max-width:860px;margin:0 auto clamp(32px,7vw,48px);padding:0 clamp(20px,5vw,48px)}
  .ad::before{content:"Advertisement";display:block;text-align:center;font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:rgba(22,18,22,.4);margin-bottom:8px}
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); }
  .guides h1 { font-family: var(--headingFont); }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
