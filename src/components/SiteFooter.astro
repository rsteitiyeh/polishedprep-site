---
/**
 * Shared site footer for non-homepage pages (articles, /guides/).
 * Mirrors the homepage <footer> markup/classes from Landing.astro.
 */
import site from '../../site.config.json';
---
<footer>
  <div class="foot-top">
    <div>
      <a class="brand" href="/">Pass<b>Cosmo</b></a>
      <p>Exam prep for cosmetology students who'd rather pass once and get behind the chair.</p>
    </div>
    <nav><a href="/#quiz">Practice Tests</a><a href="/#guide">Study Guide</a><a href="/guides/">Articles</a><a href="/#states">By State</a><a href="/#faq">FAQ</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/editorial/">Editorial</a></nav>
  </div>
  <div class="foot-bottom">
    <p>&copy; 2026 {site.BRAND} &middot; <a href="/privacy/">Privacy</a> &middot; <a href="/terms/">Terms</a> &middot; <a href="/disclosure/">Disclosure</a></p>
    <p>PassCosmo is not affiliated with PSI, Milady, or any state licensing board.</p>
  </div>
</footer>

<style is:global>
  footer{background:var(--ink,#161216);color:rgba(251,247,244,.75)}
  .foot-top{max-width:1200px;margin:0 auto;padding:clamp(48px,6vw,72px) clamp(20px,5vw,48px) 36px;display:flex;flex-wrap:wrap;gap:clamp(28px,5vw,64px);justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(251,247,244,.14)}
  .foot-top .brand{color:var(--bg,#FBF7F4)}
  .foot-top p{margin:10px 0 0;font-size:14px;line-height:1.6;color:rgba(251,247,244,.55);max-width:34ch}
  .foot-top nav{display:flex;gap:clamp(24px,4vw,48px);flex-wrap:wrap}
  .foot-top nav a{font-size:14px;color:rgba(251,247,244,.75)}
  .foot-bottom{max-width:1200px;margin:0 auto;padding:28px clamp(20px,5vw,48px) 40px;display:flex;flex-wrap:wrap;gap:16px;justify-content:space-between;align-items:center}
  .foot-bottom p{margin:0;font-size:13px;color:rgba(251,247,244,.5)}
  .foot-bottom a{color:rgba(251,247,244,.5)}
</style>
