  </main>
  <slot name="site-footer"><SiteFooter /></slot>
</Base>

<style define:vars={{ bg: t.bg, ink: t.ink, accent: t.accent, headingFont: t.headingFont, bodyFont: t.bodyFont }} is:global>
  .ad{max-width:860px;margin:0 auto clamp(32px,7vw,48px);padding:0 clamp(20px,5vw,48px)}
  .ad::before{content:"Advertisement";display:block;text-align:center;font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:rgba(22,18,22,.4);margin-bottom:8px}
  .article-wrap { max-width: 760px; margin: 0 auto; padding: 32px 20px 80px; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); }
  .article-head h1, .prose h2, .prose h3, .prose h4 { font-family: var(--headingFont); }
  .prose { font-family: var(--bodyFont); line-height: 1.75; font-size: 1.05rem; }
  .prose p { margin: 1.1em 0; }
  .prose a { color: var(--accent); }
  .prose ul, .prose ol { margin: 1.1em 0; padding-left: 1.4em; }
  .prose li { margin: 0.4em 0; }
  .prose blockquote { margin: 1.4em 0; padding: 0.6em 1.2em; border-left: 4px solid var(--accent); background: rgba(0,0,0,.03); font-style: italic; }
  .breadcrumb { font-size: 13px; opacity: .75; margin-bottom: 24px; }
  .article-head h1 { line-height: 1.15; margin: 0 0 8px; }
  .byline { font-size: 14px; opacity: .8; margin: 0 0 32px; }
  .prose h2 { margin-top: 2.2em; }
  .prose h3 { margin-top: 1.6em; }
  .prose table { border-collapse: collapse; width: 100%; margin: 1.2em 0; }
  .prose th, .prose td { border: 1px solid #d5d5d5; padding: 8px 10px; text-align: left; }
  .prose img { max-width: 100%; height: auto; }
  .cta-card { margin: 40px 0; padding: 24px; border: 1px solid #ddd; border-radius: 12px; }
  .cta-card .btn { display: inline-block; padding: 12px 20px; border-radius: 10px; color: #fff; background: var(--accent, #0E5C4A); font-weight: 700; text-decoration: none; }
  .related ul { list-style: none; padding: 0; }
  .related li { margin: 12px 0; }
</style>
