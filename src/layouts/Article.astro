---
import Base from './Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import site from '../../site.config.json';
import { extractFaq } from '../lib/faq.mjs';

interface Props {
  entry: any;        // content collection entry
  related?: { title: string; slug: string; description?: string }[];
}
const { entry, related = [] } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;
const updated = updatedDate ?? publishDate;
const authorName = author ?? site.author.name;
const canonical = new URL(`/${entry.id}/`, site.SITE).href;

const faqs = extractFaq(entry.body);
const graph = [];
graph.push({
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: authorName, url: site.SITE },
  publisher: { '@type': 'Organization', name: site.BRAND },
  datePublished: publishDate.toISOString().slice(0, 10),
  dateModified: updated.toISOString().slice(0, 10),
  mainEntityOfPage: canonical
});
if (faqs.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a }
    }))
  });
}
const jsonld = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const t = site.theme;
---
<Base title={`${title} | ${site.BRAND}`} description={description} ogType="article">
  <script type="application/ld+json" set:html={jsonld} slot="head" />
  <slot name="site-header"><SiteHeader /></slot>
  <div class="ad"></div>
  <main class="article-wrap">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> › <a href="/guides/">Articles</a> › <span>{title}</span>
    </nav>
    <article>
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=hissecret&tid=passcosmo_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">His Secret Obsession</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Relationship guide by coach James Bauer — understanding what makes partners commit.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">Read more →</span></a>
      <header class="article-head">
        <h1>{title}</h1>
        <p class="byline">
          By {authorName} · Updated <time datetime={updated.toISOString().slice(0, 10)}>{fmt(updated)}</time>
        </p>
      </header>
      <div class="prose">
        <slot />
      </div>
      <aside class="cta-card">
        <slot name="cta">
          <p><strong>Try the free tool</strong> — no signup needed.</p>
          <a class="btn" href="/#tool">Open the free tool</a>
        </slot>
      </aside>
      <div class="ad"></div>
      {related.length > 0 && (
        <section class="related">
          <h2>Related guides</h2>
          <ul>
            {related.map(r => (
              <li><a href={`/${r.slug}/`}>{r.title}</a>{r.description && <p>{r.description}</p>}</li>
            ))}
          </ul>
        </section>
      )}
    <aside class="offer-box" style="margin:2rem 0;padding:1.25rem 1.4rem;border-radius:10px;font-size:0.95em;line-height:1.6;background:rgba(0,0,0,0.04);border-left:4px solid currentColor">
